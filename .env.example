# ════════════════════════════════════════════════════════════════════════════════
# PROMPT Genie Root Workspace — Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env at the root directory
# For backend-specific env variables, see orionstack-backend--main/.env.example
# For Flutter app configuration, see thepg/.env (if needed)
# NEVER commit .env to version control
#
# Generate secrets with:
#   JWT_SECRET=$(openssl rand -base64 64)
#   JWT_REFRESH_SECRET=$(openssl rand -base64 64)
# ════════════════════════════════════════════════════════════════════════════════

# ─ ENVIRONMENT & VERSION ─────────────────────────────────────────────────────────
NODE_ENV=development
APP_VERSION=1.0.0
NODE_VERSION=18+
DART_VERSION=3.0+
FLUTTER_VERSION=3.2+

# ─ PORTS & SERVICES ──────────────────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=5000
DATABASE_PORT=5432
NGINX_PORT=80
NGINX_SSL_PORT=443

# ─ DATABASE (PostgreSQL 15) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=promptgenie_dev
DB_CONNECTION_LIMIT=20
DB_IDLE_TIMEOUT=30000

# ─ REDIS (Redis 7) ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECTION_TIMEOUT=5000

# ─ JWT AUTHENTICATION ─────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secure-jwt-secret-min-64-chars-change-in-production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars-change-in-production
JWT_REFRESH_EXPIRY=30d

# ─ ENCRYPTION & SECURITY ──────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
PIN_ENCRYPTION_KEY=your-32-char-encryption-key
PIN_ENCRYPTION_IV=your-16-char-iv
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ─ API & FRONTEND CONFIGURATION ───────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5000
API_BASE_URL=http://localhost:3000/api/v1
PUBLIC_BACKEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000/api/v1

# ─ CORS SETTINGS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5000,http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ─ EMAIL CONFIGURATION (SendGrid) ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
EMAIL_FROM=noreply@genieinprompt.app
EMAIL_FROM_NAME=PROMPT Genie
EMAIL_SUPPORT=support@genieinprompt.app

# ─ SMS CONFIGURATION (Twilio) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─ FILE STORAGE ────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=./uploads
MAX_FILE_SIZE=10485760
MAX_FILE_SIZE_MB=100

# ─ AWS CONFIGURATION (Optional - for production) ────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_PREFIX=uploads/

# ─ LOGGING CONFIGURATION ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=30

# ─ RATE LIMITING ────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_REQUESTS=100
AUTH_RATE_LIMIT=5

# ─ FEATURE FLAGS ────────────────────────────────────────────────────────────────────
BIOMETRIC_AUTH_ENABLED=true
OFFLINE_MODE_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=false
REAL_TIME_CHAT_ENABLED=true
RIDE_HAILING_ENABLED=true
FINANCIAL_OPERATIONS_ENABLED=true
AI_FEATURES_ENABLED=false

# ─ DOCKER & DEPLOYMENT ────────────────────────────────────────────────────────────
DOCKER_REGISTRY=
DOCKER_IMAGE_NAME=promptgenie-backend
DOCKER_IMAGE_TAG=1.0.0-latest

# ─ CI/CD & AUTOMATION ──────────────────────────────────────────────────────────────
CI_ENABLED=false
CD_ENABLED=false
GITHUB_TOKEN=
DEPLOY_KEY=

# ─ MONITORING & ANALYTICS ────────────────────────────────────────────────────────
SENTRY_DSN=
FIREBASE_PROJECT_ID=
ANALYTICS_ENABLED=false

# ─ TIMEZONE & LOCALIZATION ────────────────────────────────────────────────────────
TZ=UTC
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de

# ─ DEVELOPMENT & DEBUG ────────────────────────────────────────────────────────────
DEBUG_MODE=false
VERBOSE_LOGGING=false
PROFILING_ENABLED=false
ENABLE_SWAGGER=true
SWAGGER_PATH=/api/docs

# AI Services
AI_ENABLED=true
TENSORFLOW_ENABLED=false
AI_API_KEY=your_openai_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
AI_TOP_P=0.9
AI_REQUEST_TIMEOUT=30000
AI_FRAUD_BLOCK_THRESHOLD=0.85
AI_FRAUD_REVIEW_THRESHOLD=0.55
AI_SURGE_MAX_MULTIPLIER=3.5
AI_PLATFORM_FEE_PCT=8
ML_MODEL_PATH=./ml-models
FEATURE_STORE_UPDATE_INTERVAL=300000

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Monitoring
HEALTH_CHECK_TIMEOUT=30000
METRICS_ENABLED=true
